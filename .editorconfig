# EditorConfig is awesome: https://editorconfig.org

# top-most EditorConfig file
root = true

[*]
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Shell scripts
[*.{sh,bash}]
binary_next_line = true
indent_size = 2
keep_padding       = true
space_redirects    = true
switch_case_indent = true

# Yaml files
[*.{yml,yaml}]
indent_size = 2
